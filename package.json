{
  "name": "antares",
  "version": "1.0.0",
  "description": "App de escritorio para radios públicas e IPTV del usuario",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron --disable-gpu .",
    "dist:win": "electron-builder --win nsis"
  },
  "author": "Gerardo Morel",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "hls.js": "^1.6.16"
  },
  "build": {
    "appId": "com.gerardomorel.antares",
    "productName": "Antares",
    "directories": {
      "buildResources": "assets/icons"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/Antares_icono.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
